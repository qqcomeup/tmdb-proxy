# TMDB Proxy 环境配置示例
# 复制此文件为 .env 并填入实际值

# 服务器配置
PORT=3000
NODE_ENV=production

# TMDB API 配置 (可选 - 也可以通过请求头传递)
# TMDB_API_KEY=your_tmdb_api_key_here

# 管理后台密码 (建议设置一个复杂密码)
# ADMIN_API_KEY=your_secure_admin_key

# 安全配置
# 屏蔽的国家代码 (逗号分隔)
# BLOCKED_COUNTRIES=CN,RU

# 速率限制配置
RATE_LIMIT_WINDOW_MS=900000  # 15分钟
RATE_LIMIT_MAX_REQUESTS=1000  # 每个IP最大请求数

# 缓存配置
IMAGE_CACHE_TTL=604800  # 图片缓存时间 (7天)
API_CACHE_TTL=600       # API缓存时间 (10分钟)

# 日志配置
LOG_LEVEL=info
LOG_FILE=/app/logs/tmdb-proxy.log

# Redis 配置 (如果使用 Redis 缓存)
# REDIS_URL=redis://redis:6379
# REDIS_PASSWORD=

# 监控配置
HEALTH_CHECK_INTERVAL=30000  # 健康检查间隔 (毫秒)
